<Project>
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://homeworkoutwebapp.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ProjectGuid>295ca7bf-135c-4321-b742-1f7ea071064e</ProjectGuid>
    <PublishUrl>https://homeworkoutwebapp.scm.azurewebsites.net/</PublishUrl>
    <UserName>$HomeWorkoutWebApp</UserName>
    <_SavePWD>true</_SavePWD>
  </PropertyGroup>
</Project>