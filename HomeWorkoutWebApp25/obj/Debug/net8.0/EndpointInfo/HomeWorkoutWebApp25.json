  "components": {
    "schemas": {
      "BodyPartDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "bodyPartName": {
            "type": "string",
            "nullable": true
          },
          "exercises": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExerciseDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ExerciseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "exerciseName": {
            "type": "string",
            "nullable": true
          },
          "exerciseDescription": {
            "type": "string",
            "nullable": true
          },
          "difficulty": {
            "maximum": 5,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "bodyPartId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginVM": {
        "required": [
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "returnUrl": {
            "type": "string",
            "nullable": true
          },
          "remember": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "RoleModification": {
        "required": [
          "roleName"
        ],
        "type": "object",
        "properties": {
          "roleName": {
            "minLength": 1,
            "type": "string"
          },
          "roleId": {
            "type": "string",
            "nullable": true
          },
          "addIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "deleteIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserVM": {
        "required": [
          "email",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$",
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "WorkoutExerciseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "sets": {
            "type": "integer",
            "format": "int32"
          },
          "reps": {
            "type": "integer",
            "format": "int32"
          },
          "workoutPlanId": {
            "type": "integer",
            "format": "int32"
          },
          "exerciseId": {
            "type": "integer",
            "format": "int32"
          },
          "checked": {
            "type": "boolean",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WorkoutPlanDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "exercises": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkoutExerciseDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
